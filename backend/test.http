# ============================================================
# USERS
# ============================================================

### 1. Register User 1
POST {{baseUrl}}/api/users/register
Content-Type: application/json

{
    "firstName": "Lyle Tristan",
    "lastName": "Rivera",
    "email": "riveralm@students.national-u.edu.ph",
    "password": "123123",
}

###

### 2. Register User 2
POST {{baseUrl}}/api/users/register
Content-Type: application/json

{
    "firstName": "Maria",
    "lastName": "Santos",
    "email": "maria@students.national-u.edu.ph",
    "password": "123456",
}

###

###

### 3. Log in as Admin
{
    "email": "admin@national-u.edu.ph",
    "password": "admin1234"
}

### 4. Login User (copy token from response into @token above)
POST {{baseUrl}}/api/users/login
Content-Type: application/json

{
    "email": "maria@national-u.edu.ph",
    "password": "myPassword123"
}

###

### 5. Get my profile (requires token)
GET {{baseUrl}}/api/users/profile
x-auth-token: {{token}}

###

### 6. Update my profile (requires token)
PUT {{baseUrl}}/api/users/profile
Content-Type: application/json
x-auth-token: {{token}}

{
    "firstName": "Juan",
    "lastName": "Dela Cruz",
    "contactNumber": "09171234567",
    "messengerLink": "https://m.me/juandelacruz",
    "profileImage": "https://example.com/photo.jpg"
}

###

### 7. Change password (requires token)
PUT {{baseUrl}}/api/users/change-password
Content-Type: application/json
x-auth-token: {{token}}

{
    "currentPassword": "myPassword123",
    "newPassword": "newPassword456"
}

###

### 8. Get any user's public profile (replace 1 with real UserID)
GET {{baseUrl}}/api/users/1


# ============================================================
# CATEGORIES
# ============================================================

### 9. Get all categories
GET {{baseUrl}}/api/categories

###

### 10. Get single category by ID
GET {{baseUrl}}/api/categories/1


# ============================================================
# PRODUCTS
# ============================================================

### 11. Get all available products
GET {{baseUrl}}/api/products

###

### 12. Search by keyword
GET {{baseUrl}}/api/products?search=textbook

###

### 13. Filter by category ID
GET {{baseUrl}}/api/products?category=1

###

### 14. Filter by condition
GET {{baseUrl}}/api/products?condition=Used

###

### 15. Filter by price range and sort
GET {{baseUrl}}/api/products?minPrice=100&maxPrice=500&sort=price_asc

###

### 16. Get all products including sold
GET {{baseUrl}}/api/products?status=Sold

###

### 17. Get single product by ID (replace 1 with real ProductID)
GET {{baseUrl}}/api/products/1

###

### 18. Get my listings (requires token)
GET {{baseUrl}}/api/products/my/listings
x-auth-token: {{token}}

###

### 19. Add a new product (requires token)
POST {{baseUrl}}/api/products/add
Content-Type: application/json
x-auth-token: {{token}}

{
    "productName": "Engineering Physics Textbook",
    "price": 500.00,
    "description": "Slightly used, no highlights. Great for physics midterms!",
    "productCondition": "Used",
    "categoryID": 1,
    "quantity": 1,
    "imageURL": "https://example.com/textbook.jpg"
}

###

### 20. Edit a product (replace 1 with real ProductID)
PUT {{baseUrl}}/api/products/12
Content-Type: application/json
x-auth-token: {{token}}

{
    "productName": "Engineering Physics Textbook (Updated)",
    "price": 450.00,
    "description": "Price lowered! Still in great condition.",
    "productCondition": "Used",
    "categoryID": 1,
    "quantity": 1,
    "imageURL": "https://example.com/textbook.jpg"
}

###

### 21. Mark product as sold
PATCH {{baseUrl}}/api/products/12/sold
x-auth-token: {{token}}

###

### 22. Delete a product
DELETE {{baseUrl}}/api/products/12
x-auth-token: {{token}}


# ============================================================
# TRANSACTIONS
# NOTE: Login as MARIA before running #22
# ============================================================

### 23. Buy a product (login as Maria, replace ProductID)
POST {{baseUrl}}/api/transactions
Content-Type: application/json
x-auth-token: {{token}}

{
    "productID": 11
}

###

### 24. Get my purchases (login as buyer)
GET {{baseUrl}}/api/transactions/my/purchases
x-auth-token: {{token}}

###

### 25. Get my sales (login as seller)
GET {{baseUrl}}/api/transactions/my/sales
x-auth-token: {{token}}

###

### 26. Get single transaction (replace 1 with real TransactionID)
GET {{baseUrl}}/api/transactions/4
x-auth-token: {{token}}

###

### 27. Update transaction status (login as Juan/seller, replace 1 with real TransactionID)
### Valid values: Pending, Completed, Cancelled
PATCH {{baseUrl}}/api/transactions/4/status
Content-Type: application/json
x-auth-token: {{token}}

{
    "status": "Completed"
}


# ============================================================
# REVIEWS
# NOTE: Transaction must be Completed first
# Login as Maria (buyer) before running #27
# ============================================================

### 28. Submit a review (login as buyer, replace TransactionID)
POST {{baseUrl}}/api/reviews
Content-Type: application/json
x-auth-token: {{token}}

{
    "transactionID": 4,
    "rating": 5,
    "comment": "Great seller! Item was exactly as described. 10/10!"
}

###

### 29. Get all reviews for a user (replace 1 with real UserID)
GET {{baseUrl}}/api/reviews/user/3

###

### 30. Get single review (replace 1 with real ReviewID)
GET {{baseUrl}}/api/reviews/4

###

### 31. Delete a review (replace 1 with real ReviewID)
DELETE {{baseUrl}}/api/reviews/4
x-auth-token: {{token}}